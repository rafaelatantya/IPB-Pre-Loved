{
  "name": "ipb-pre-loved",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npm run pages:build && npx wrangler pages dev .vercel/output/static --d1 DB=777ac36d-0a4f-4996-9c38-201fed833d73 --r2 BUCKET --persist-to ./local-db-info",
    "db:generate": "drizzle-kit generate",
    "db:push:local": "echo \"y\" | npx wrangler d1 migrations apply DB --local --persist-to ./local-db-info",
    "db:push:remote": "npx wrangler d1 migrations apply DB --remote",
    "db:wipe": "rm -rf .wrangler/state ./local-db-info && npm run db:push:local"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaelatantya/IPB-Pre-Loved.git"
  },
