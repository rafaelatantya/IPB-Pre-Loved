    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@cloudflare/workers-types": "^4.20260416.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@tailwindcss/postcss": "^4.2.3",
    "autoprefixer": "^10.5.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.84.0"
  }
}
